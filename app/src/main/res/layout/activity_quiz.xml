<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A2E">

    <!-- Question counter -->
    <TextView
        android:id="@+id/tvQuestionNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Question 1 of 10"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="24dp" />

    <!-- Flashcard -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="#16213E"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <TextView
            android:id="@+id/tvStatement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="Statement goes here"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:lineSpacingExtra="6dp" />

    </androidx.cardview.widget.CardView>

    <!-- Answer Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnHack"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="✅ HACK"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F9B58" />

        <Button
            android:id="@+id/btnMyth"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="❌ MYTH"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E94560" />

    </LinearLayout>

    <!-- Feedback Text -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Correct! That's a real time-saver!"
        android:textSize="16sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:visibility="invisible" />

    <!-- Next Button -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="160dp"
        android:layout_height="52dp"
        android:text="NEXT ➡"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#533483"
        android:visibility="invisible" />

</LinearLayout>