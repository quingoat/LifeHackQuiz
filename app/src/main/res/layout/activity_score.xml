<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <!-- Trophy emoji -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆"
        android:textSize="72sp"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quiz Complete!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E94560"
        android:layout_marginBottom="16dp" />

    <!-- Score -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You scored 8 out of 10"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Personalised Feedback -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Great job! You really know your hacks!"
        android:textSize="16sp"
        android:textColor="#FFD700"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Review Button -->
    <Button
        android:id="@+id/btnReview"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="📋 REVIEW ANSWERS"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#533483"
        android:layout_marginBottom="16dp" />

    <!-- Play Again Button -->
    <Button
        android:id="@+id/btnPlayAgain"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="🔄 PLAY AGAIN"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0F9B58" />

</LinearLayout>